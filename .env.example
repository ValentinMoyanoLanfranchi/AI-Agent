# =============================================================
# SISTEMA DE AGENTES IA - HACKATHON JUNIO 2026
# Copiar este archivo como .env y llenar los valores reales
# =============================================================

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=hackaton
POSTGRES_PASSWORD=hackaton_pass
POSTGRES_DB=hackaton_db
DATABASE_URL=postgresql+asyncpg://hackaton:hackaton_pass@db:5432/hackaton_db
DATABASE_URL_SYNC=postgresql://hackaton:hackaton_pass@db:5432/hackaton_db

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── NASA APIs ────────────────────────────────────────────────
# Obtener en: https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

# NASA Earthdata (alternativa gratuita a Sentinel Hub)
# Registrarse en: https://urs.earthdata.nasa.gov/
NASA_EARTHDATA_USER=your_earthdata_username
NASA_EARTHDATA_PASSWORD=your_earthdata_password

# ─── LLM Providers ────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Modelo a usar por agente (puede ser el mismo para todos)
DEFAULT_LLM_MODEL=gpt-4o
AGENT1_MODEL=gpt-4o
AGENT2_MODEL=gpt-4o
AGENT3_MODEL=gpt-4o
AGENT4_MODEL=claude-3-5-sonnet-20241022
AGENT5_MODEL=gpt-4o

LLM_TEMPERATURE=0.1

# ─── Notificaciones ───────────────────────────────────────────
# Resend (emails): https://resend.com/
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM_EMAIL=alerts@yourdomain.com
RESEND_TO_EMAIL=team@yourdomain.com

# Slack Webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─── App Config ───────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Umbrales de alertas
KP_INDEX_THRESHOLD=5.0          # Umbral índice Kp para alertas geomagnéticas
NDVI_ANOMALY_THRESHOLD=-0.15    # Caída de NDVI que activa alerta
DISASTER_PROXIMITY_KM=50.0      # Radio km para alertas de desastre
